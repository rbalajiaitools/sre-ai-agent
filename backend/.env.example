# Application
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://sre_user:sre_password@postgres:5432/sre_agent

# Redis
REDIS_URL=redis://redis:6379/0

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# ServiceNow Incident Filtering
# Options: date, numbers, all
SERVICENOW_INCIDENT_FILTER_MODE=date
# For date mode: ISO format date (YYYY-MM-DD)
SERVICENOW_INCIDENT_FILTER_DATE=2026-04-01
# For numbers mode: comma-separated incident numbers
SERVICENOW_INCIDENT_FILTER_NUMBERS=INC0010001,INC0010002
