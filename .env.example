# Database Configuration
CSAA_DATABASE_URL=postgresql+asyncpg://astra_user:astra_password@localhost:5432/astra_db
CSAA_DATABASE_POOL_SIZE=20
CSAA_DATABASE_MAX_OVERFLOW=10
CSAA_DATABASE_ECHO=false

# Redis Configuration
CSAA_REDIS_URL=redis://localhost:6379/0
CSAA_REDIS_MAX_CONNECTIONS=50

# Kafka Configuration
CSAA_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
CSAA_KAFKA_CLIENT_ID=astra-ai
CSAA_KAFKA_GROUP_ID=astra-ai-group

# Temporal Configuration
CSAA_TEMPORAL_HOST=localhost
CSAA_TEMPORAL_PORT=7233
CSAA_TEMPORAL_NAMESPACE=default
CSAA_TEMPORAL_TASK_QUEUE=astra-ai-tasks

# JWT Configuration
CSAA_JWT_SECRET=your-secret-key-change-in-production-use-strong-random-string
CSAA_JWT_ALGORITHM=HS256
CSAA_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
CSAA_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging Configuration
CSAA_LOG_LEVEL=INFO
CSAA_LOG_FORMAT=json

# Service Configuration
SERVICE_NAME=astra-ai
ENVIRONMENT=development

# AI/LLM Configuration (for AI Engine service)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Eraser.io Configuration (for Eraser service)
CSAA_ERASER_API_KEY=your-eraser-api-key
